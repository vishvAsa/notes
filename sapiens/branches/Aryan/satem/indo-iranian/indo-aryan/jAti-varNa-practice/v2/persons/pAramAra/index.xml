    <item>
      <title>mihira-bhoja</title>
      <link>https://vishvAsa.github.io/notes/sapiens/branches/Aryan/satem/indo-iranian/indo-aryan/jAti-varNa-practice/v2/persons/pAramAra/mihira-bhoja/</link>
