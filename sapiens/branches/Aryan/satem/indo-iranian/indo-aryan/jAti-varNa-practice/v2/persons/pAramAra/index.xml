    <item>
      <title>karNAvatI</title>
      <link>https://vishvAsa.github.io/notes/sapiens/branches/Aryan/satem/indo-iranian/indo-aryan/jAti-varNa-practice/v2/persons/pAramAra/karNAvatI/</link>
